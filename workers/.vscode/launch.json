{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "workers · Celery",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": ["-A", "workers.celery_app", "worker", "--loglevel=info", "--pool=solo"],
      "cwd": "${workspaceFolder}/..",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
